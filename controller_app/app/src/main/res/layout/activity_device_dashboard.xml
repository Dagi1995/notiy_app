<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/deviceNameTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Device Name"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/editNameButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Nickname"
        android:layout_gravity="center"
        style="?attr/borderlessButtonStyle"
        android:textColor="#6200EE"
        android:textSize="12sp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="20dp"
        android:elevation="2dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/dashboardBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Battery: --%"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/dashboardAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessibility: --"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/dashboardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: --"
            android:textSize="16sp" />
    </LinearLayout>

    <Button
        android:id="@+id/ussdControlBtn"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="📞 USSD CONTROL"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#6200EE"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/smsLogsBtn"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="✉️ SMS LOGS"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#018786"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/deleteDeviceBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑️ DELETE DEVICE"
        android:textColor="#F44336"
        style="?attr/borderlessButtonStyle"
        android:layout_marginTop="16dp" />

</LinearLayout>
